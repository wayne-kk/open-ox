# /etc/nginx/conf.d/open-ox.tech.conf
# Open-OX → Docker / Node on 127.0.0.1:3000
#
# Install:
#   sudo cp deploy/open-ox.tech.conf.example /etc/nginx/conf.d/open-ox.tech.conf
#   # First boot: keep only the :80 server (comment out the :443 block) until certbot succeeds
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d open-ox.tech -d www.open-ox.tech
#   sudo nginx -t && sudo systemctl reload nginx
#
# If wayne.xin / wayne.beer conf is still enabled and shares the same upstream name,
# either disable those files or rename this upstream to avoid duplicate `upstream` errors.

upstream open_ox_app {
    server 127.0.0.1:3000;
    keepalive 32;
}

# HTTP — ACME + redirect to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name open-ox.tech www.open-ox.tech;

    location ^~ /.well-known/acme-challenge/ {
        root /var/www/certbot;
        allow all;
    }

    location / {
        return 301 https://open-ox.tech$request_uri;
    }
}

# HTTPS
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name open-ox.tech www.open-ox.tech;

    # certbot --nginx will fill/replace these; paths below match a typical install
    ssl_certificate     /etc/letsencrypt/live/open-ox.tech/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/open-ox.tech/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    access_log /sharedata/wayne/open-ox/logs/nginx-access.log;
    error_log  /sharedata/wayne/open-ox/logs/nginx-error.log;

    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    if ($host = www.open-ox.tech) {
        return 301 https://open-ox.tech$request_uri;
    }

    # SSE — Studio / intent-agent / modify
    location = /api/ai/intent-agent {
        proxy_pass http://open_ox_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        gzip off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location = /api/ai {
        proxy_pass http://open_ox_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        gzip off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location ~ ^/api/projects/[^/]+/modify$ {
        proxy_pass http://open_ox_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        gzip off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # Static preview rebuild (PUT) — full next build + upload
    location ~ ^/api/projects/[^/]+/preview$ {
        proxy_pass http://open_ox_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_connect_timeout 60s;
        proxy_send_timeout 3600s;
        proxy_read_timeout 3600s;
    }

    location / {
        proxy_pass http://open_ox_app;
        proxy_http_version 1.1;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host              $host;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Supabase OAuth Set-Cookie can exceed default proxy buffer
        proxy_buffer_size          128k;
        proxy_buffers              4 256k;
        proxy_busy_buffers_size    256k;

        proxy_cache_bypass $http_upgrade;
        proxy_connect_timeout 60s;
        proxy_send_timeout    300s;
        proxy_read_timeout    300s;
    }
}
