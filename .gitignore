# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/


 .pnpm-store/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.production.example
sites/*
!sites/template/
# vercel
.vercel
.open-ox/

# typescript
*.tsbuildinfo
next-env.d.ts

# tsc compiled output in source dirs (should never be committed)
ai/**/*.js
ai/**/*.d.ts
ai/**/*.js.map
ai/**/*.d.ts.map
lib/**/*.d.ts
lib/**/*.d.ts.map
lib/**/*.js.map

# sdk build artifacts
sdk/dist/
sdk/src/engine/flows/
sdk/src/engine/shared/
sdk/src/engine/tools/
sdk/src/engine/prompts/
sdk/src/engine/prompt-files/
sdk/src/engine/shims/
sdk-real-test/
/sdk/