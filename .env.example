# Open-OX environment template
# Copy to .env.local for local development:
#   cp .env.example .env.local
# Validate Core vars:
#   pnpm check:env
#
# Tiers:
#   Core          — required for a meaningful run (auth + LLM + Studio)
#   Auth          — optional login providers (hide UI when unset)
#   Integrations  — Stripe / Vercel / E2B / image gen (feature-gated)
#   Ops           — observability, tunables, feature flags (defaults exist)

# =============================================================================
# Core (required)
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public origin of this app (no trailing slash). Also used for OAuth redirects / SEO.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public filing labels shown in the site footer. Use the complete official display text.
# NEXT_PUBLIC_ICP_FILING_NUMBER=京ICP备12345678号-1
# NEXT_PUBLIC_PUBLIC_SECURITY_FILING_NUMBER=京公网安备11000002000001号

# OpenAI-compatible API (any provider that speaks the Chat Completions API)
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4.1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Auth (optional)
# =============================================================================

# Feishu OAuth — all four required to enable the Feishu login button
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_OAUTH_HMAC_SECRET=
# FEISHU_OAUTH_SCOPE=
# Feishu Bot events (Modify MVP) — verification token from the Feishu app event subscription
# FEISHU_VERIFICATION_TOKEN=

# Feishu custom group bot for at-most-once new-user registration notifications.
# The Webhook URL is required. The secret is optional unless signature verification is enabled.
# FEISHU_NEW_USER_WEBHOOK_URL=
# FEISHU_NEW_USER_WEBHOOK_SECRET=

# Linux.do Connect OAuth — register at https://connect.linux.do
# Callback URL: {NEXT_PUBLIC_SITE_URL}/api/auth/linuxdo/callback
# LINUXDO_CLIENT_ID=
# LINUXDO_CLIENT_SECRET=
# LINUXDO_OAUTH_HMAC_SECRET=
# Required when the server network cannot reach connect.linux.do directly.
# HTTPS_PROXY=http://127.0.0.1:7890

# Google OAuth — configure the provider in Supabase Dashboard.
# Set GOOGLE_LOGIN_ENABLED=false to hide the button even when Supabase is set.
# GOOGLE_LOGIN_ENABLED=true

# =============================================================================
# Integrations (optional — capability-gated)
# =============================================================================

# Credits / billing. Off by default — apply migrations 026 + 027 first.
# CREDITS_ENABLED=1
# CREDITS_USD_PER_CREDIT=0.25
# CREDITS_MARGIN=1

# Stripe (Pro + top-ups). Create Products/Prices in Stripe Dashboard, paste Price IDs.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO_100=price_...
# STRIPE_PRICE_PRO_200=price_...
# STRIPE_PRICE_PRO_400=price_...
# STRIPE_PRICE_TOPUP_50=price_...
# STRIPE_PRICE_TOPUP_100=price_...
# STRIPE_PRICE_TOPUP_200=price_...

# BYO Vercel Deploy. Apply migration 029_vercel_deploy.sql.
# Create a Vercel Integration; Redirect URL =
#   {NEXT_PUBLIC_SITE_URL}/api/integrations/vercel/callback
# VERCEL_CLIENT_ID=
# VERCEL_CLIENT_SECRET=
# VERCEL_INTEGRATION_SLUG=
# VERCEL_TOKEN_ENCRYPTION_KEY=
# VERCEL_REDIRECT_URI=
# If https://vercel.com/integrations/<slug>/new 404s, paste Install URL from console:
# VERCEL_INSTALL_URL=https://vercel.com/integrations/<slug>/new

# Preview backend: local (default) | storage | e2b
# OPEN_OX_PREVIEW_BACKEND=local
# E2B_API_KEY=

# Dedicated static-preview origin (Form 1). Different host from NEXT_PUBLIC_SITE_URL.
# Example: SITE=https://app.example.com → PREVIEW=https://p.example.com
# Public URL becomes https://p.example.com/{projectId} (rewritten to /site-previews/...).
# Point DNS for p.* at the same app; rebuild/resync previews after enabling (basePath changes).
# Local: http://p.localhost:3000 (browsers resolve *.localhost) + add to OPEN_OX_ALLOWED_DEV_ORIGINS.
# NEXT_PUBLIC_PREVIEW_ORIGIN=https://p.example.com
#
# Process-local Storage cache for hashed _next/static (warm chunks skip Supabase RTT).
# OPEN_OX_PREVIEW_UPSTREAM_CACHE_ENTRIES=256
# OPEN_OX_PREVIEW_UPSTREAM_CACHE_BYTES=67108864
# OPEN_OX_PREVIEW_UPSTREAM_CACHE_TTL_MS=3600000

# Volcengine Ark image generation (optional)
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_IMAGE_MODEL=doubao-seedream-4-0-250828
# ARK_IMAGE_MAX_CONCURRENCY=2

# =============================================================================
# Ops / tunables (optional)
# =============================================================================

# Langfuse tracing
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Model overrides
# MODIFY_MODEL=
# MODIFY_COMPLEX_MODEL=gemini-3.1-pro-preview

# Design Mode (Studio)
# NEXT_PUBLIC_STUDIO_DESIGN_MODE=1

# Preview / static export knobs
# OPEN_OX_PREVIEW_PORT=
# OPEN_OX_PREVIEW_PUBLIC_HOST=
# OPEN_OX_SKIP_STATIC_PREVIEW_PUBLISH=1
# OPEN_OX_COVER_CAPTURE=0
# Shared secret for Playwright cover capture against /site-previews (avoids spinning next per site).
# OPEN_OX_PREVIEW_CAPTURE_SECRET=
# Recycle Bin auto-purge: GET|POST /api/internal/purge-trashed-projects
# Authorization: Bearer <secret>. Vercel Cron uses CRON_SECRET (see vercel.json).
# OPEN_OX_CRON_SECRET=
# CRON_SECRET=
# OPEN_OX_REFERENCE_PLAYWRIGHT=0
# OPEN_OX_ALLOWED_DEV_ORIGINS=http://localhost:3000

# Generation worker
# OPEN_OX_INLINE_GENERATION=1
# OPEN_OX_GENERATION_LEASE_SECONDS=240
# OPEN_OX_GENERATION_POLL_MS=500
# OPEN_OX_WORKER_ID=

# Agent / pipeline tuning
# PAGE_IMPLEMENT_AGENT_MAX_ITERATIONS=
# PAGE_IMPLEMENT_AGENT_BOOTSTRAP=
# ENABLE_SCREENSHOT_REPLICA_PIPELINE=1
# DISABLE_PREBUILD_TSC=1
# DESIGN_SYSTEM_SKILL_FAST_PATH=0  # set to 0 to force bespoke LLM design-system generation
# LLM_CONNECT_TIMEOUT_MS=

# Playwright (cover / reference capture)
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
