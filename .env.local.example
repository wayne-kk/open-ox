# ── Supabase ───────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
# Public site URL (OAuth redirects / reverse-proxy). Local: http://localhost:3000. Production: https://your-domain.com (must not be localhost in deploy)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NOTE: NEXT_PUBLIC_SITE_URL drives OAuth redirects. For **local** Studio preview, if this URL’s hostname is a
# private LAN IP (192.168.x / 10.x / 172.16–31.x) or *.local, preview iframes use that host too; otherwise set
# OPEN_OX_PREVIEW_PUBLIC_HOST or only the same machine can load preview (127.0.0.1).

# ── Studio project preview ─────────────────────────────────────────────────────
# **Local dev default** (`next dev`): if SUPABASE_SERVICE_ROLE_KEY + NEXT_PUBLIC_SUPABASE_URL +
# NEXT_PUBLIC_SITE_URL are set and OPEN_OX_PREVIEW_BACKEND is **unset**, preview uses **Storage CDN**
# (`site-previews` bucket + `/site-previews/...` proxy on this app — same as typical prod).
# Force classic per-site `next dev` in iframe instead:
# OPEN_OX_PREVIEW_BACKEND=local
# Cloud sandbox:
# OPEN_OX_PREVIEW_BACKEND=e2b
# Explicit Storage (redundant in dev when defaulting to storage, useful in prod Compose if needed):
# OPEN_OX_PREVIEW_BACKEND=storage
#
# Legacy local-only preview notes (when OPEN_OX_PREVIEW_BACKEND=local):
# Default: each generated site runs `next dev` on 127.0.0.1 — only this machine can open the iframe.
# For teammates on the same LAN (or via tunnel hostname), set host WITHOUT scheme:
# OPEN_OX_PREVIEW_PUBLIC_HOST=192.168.1.10
# OPEN_OX_PREVIEW_PORT=3010
# (fixed port = easier firewall than random preview ports)
# If the preview iframe shows 「未发送任何数据」but the same URL opens in a new tab: Next.js blocks dev `/_next/`
# when Studio (e.g. localhost:3000) and the child `next dev` use different loopback names. The template sets
# `allowedDevOrigins`; use Rebuild Preview (or restart preview) once so sites pick up synced `next.config.ts`.
# Optional extra hosts inherited by spawned preview processes:
# OPEN_OX_PREVIEW_ALLOWED_DEV_ORIGINS=my.custom.hostname
#
# Public static preview: run migration `020_site_previews_bucket.sql`; requires SERVICE_ROLE for upload.
# If uploads log `fetch failed`, try lowering parallel uploads: OPEN_OX_STATIC_UPLOAD_CONCURRENCY=4

# If you open Open-Ox via LAN IP (e.g. http://192.168.31.254:3000), Next 16+ may warn about cross-origin `/_next/*`.
# Comma-separated hosts or origins for `allowedDevOrigins` (see Next.js docs), e.g.:
# OPEN_OX_ALLOWED_DEV_ORIGINS=192.168.31.254
# OPEN_OX_ALLOWED_DEV_ORIGINS=192.168.31.254,10.0.0.5

# Feishu login (server-mediated: /api/auth/feishu/* — no Supabase Custom OIDC Issuer needed)
# Production: set all four values below on your host (Vercel/Railway/etc.); missing any disables the Feishu button + flow.
# App credentials from Feishu Open Platform; redirect URL must be {NEXT_PUBLIC_SITE_URL}/api/auth/feishu/callback
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Long random string — used to derive a stable password for the Supabase user (rotate carefully)
FEISHU_OAUTH_HMAC_SECRET=
# Server-only — Settings → API → service_role (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=
# Background generation worker (`pnpm run generation:worker`, migration `019_generation_runs_*`) claims jobs via RPC; requires SERVICE_ROLE_KEY in env.
# OPEN_OX_WORKER_ID=my-host
# OPEN_OX_GENERATION_LEASE_SECONDS=240
# OPEN_OX_GENERATION_POLL_MS=1500

# After generation, captures a 1480×960 JPEG of the preview home for the projects list (`018_project_cover_image` migration).
# Server needs `pnpm exec playwright install chromium`. Disable with OPEN_OX_COVER_CAPTURE=0
# OPEN_OX_COVER_CAPTURE=0
#
# External reference URLs (intent + analyze): viewport screenshot + vision digest. Set to 0 for HTML-only fallback.
# OPEN_OX_REFERENCE_PLAYWRIGHT=0
# OPEN_OX_COVER_ALLOWED_HOST_SUFFIX=.your-reverse-proxy-domain.com
# Default GET /api/projects/:id/cover uses a 302 signed URL to Storage; set to 1 to proxy bytes through Next (slower).
# OPEN_OX_COVER_PROXY_BYTES=1

# Optional; default is open_id
# FEISHU_OAUTH_SCOPE=openid

# ── E2B Sandbox ────────────────────────────────────────────────────────────────
# Get from https://e2b.dev/dashboard
E2B_API_KEY=your-e2b-api-key

# ── LLM Provider ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-api-key
OPENAI_API_URL=https://api.openai.com/v1
# OPENAI_MODEL=gemini-3-flash-preview

# ── Optional: Dify (Style Eval) ───────────────────────────────────────────────
# DIFY_API_URL=http://47.94.241.58:9000/v1
# DIFY_API_KEY=

# ── Optional: Ark AI 图片生成（generate_image tool）──────────────────────────────
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_IMAGE_MODEL=doubao-seedream-4-0-250828
# ARK_IMAGE_SIZE=2k
