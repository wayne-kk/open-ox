# ── Supabase ───────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
# Public site URL (OAuth redirects / reverse-proxy). Local: http://localhost:3000. Production: https://your-domain.com (must not be localhost in deploy)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Feishu login (server-mediated: /api/auth/feishu/* — no Supabase Custom OIDC Issuer needed)
# Production: set all four values below on your host (Vercel/Railway/etc.); missing any disables the Feishu button + flow.
# App credentials from Feishu Open Platform; redirect URL must be {NEXT_PUBLIC_SITE_URL}/api/auth/feishu/callback
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Long random string — used to derive a stable password for the Supabase user (rotate carefully)
FEISHU_OAUTH_HMAC_SECRET=
# Server-only — Settings → API → service_role (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=
# Optional; default is open_id
# FEISHU_OAUTH_SCOPE=openid

# ── E2B Sandbox ────────────────────────────────────────────────────────────────
# Get from https://e2b.dev/dashboard
E2B_API_KEY=your-e2b-api-key

# ── LLM Provider ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-api-key
OPENAI_API_URL=https://api.openai.com/v1
# OPENAI_MODEL=gemini-3-flash-preview

# ── Optional: Dify (Style Eval) ───────────────────────────────────────────────
# DIFY_API_URL=http://47.94.241.58:9000/v1
# DIFY_API_KEY=

# ── Optional: Ark AI 图片生成（generate_image tool）──────────────────────────────
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_IMAGE_MODEL=doubao-seedream-4-0-250828
# ARK_IMAGE_SIZE=2k
