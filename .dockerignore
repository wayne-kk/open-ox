# dependencies & build output
node_modules
.next
out
dist

# git & editor
.git
.gitignore
.cursor
.vscode
.idea

# env files — keep out of image except .env.local (optional: repo/CI copy for `next build`).
# WARNING: Do not commit real secrets to git; prefer CI variables + --build-arg or compose --env-file.
.env
.env.*
!.env.local
!.env.production.example
!.env.local.example

# docs & tooling (not needed for runtime image)
docs
.planning
.kiro
.github

# large / unrelated trees
e2b-template
example
.open-ox
.scratch
logs

# Per-project workspaces are bind-mounted at runtime — never send them as build context.
# Image only needs sites/template as a seed for fresh volumes (see Dockerfile runner).
# Use sites/* (not sites/) so !sites/template can re-include the seed tree.
sites/*
!sites/template/
!sites/template/**
sites/template/node_modules
sites/template/.next
sites/template/out
sites/template/.git

# test & misc
coverage
*.log
.DS_Store
tsconfig.tsbuildinfo
vitest.config.ts
wayne.conf
